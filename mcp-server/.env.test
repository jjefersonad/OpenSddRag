# Local spike .env — points at the ISOLATED test database (port 54327).
# Used only by hand to drive `opensddrag-server init` against the disposable
# test DB during the hybrid-search spike. Do NOT commit (see .gitignore).
DATABASE_URL=postgresql://opensddrag:opensddrag@localhost:54327/opensddrag_test
EMBEDDING_MODEL=all-MiniLM-L6-v2
OPENSDDRAG_PROJECT=default
AUTH_ENABLED=false
