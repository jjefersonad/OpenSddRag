# Local (sem Docker)
DATABASE_URL=postgresql://opensddrag:opensddrag@localhost:54326/opensddrag

# Se rodar o app fora do Docker mas o banco dentro:
# DATABASE_URL=postgresql://opensddrag:opensddrag@localhost:54326/opensddrag

EMBEDDING_MODEL=all-MiniLM-L6-v2
OPENSDDRAG_PROJECT=default

# Authorization — enabled by default in SSE mode.
# Set to false only for trusted internal deployments.
AUTH_ENABLED=true
