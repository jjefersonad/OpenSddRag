# Isolated test database (docker-compose.test.yml). Copy to .env.test.
# The pytest suite and CLI use TEST_DATABASE_URL when present, so experiments
# (migrations, re-embed, hybrid search) run against this disposable DB instead
# of production.
TEST_POSTGRES_USER=opensddrag
TEST_POSTGRES_PASSWORD=opensddrag
TEST_POSTGRES_DB=opensddrag_test
TEST_DB_PORT=54327
TEST_DATABASE_URL=postgresql://opensddrag:opensddrag@localhost:54327/opensddrag_test
